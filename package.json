{
  "name": "rewardhub",
  "private": true,
  "version": "14.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build && mkdir -p dist && cp -r www/* dist/",
    "preview": "vite preview",
    "clean": "rm -rf www dist",
    "lint": "tsc --noEmit",
    "cap:add": "cap add android",
    "cap:add:ios": "cap add ios",
    "cap:sync": "cap sync android",
    "cap:sync:ios": "cap sync ios",
    "build:android": "npm run build && npx cap sync android",
    "build:ios": "npm run build && npx cap sync ios",
    "appflow:build:before": "npm run build && if [ ! -d ios ]; then npx cap add ios; else npx cap sync ios; fi"
  },
  "dependencies": {
    "@capacitor-community/admob": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/browser": "^6.0.6",
    "@capacitor/clipboard": "^6.0.3",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.4",
    "@capacitor/toast": "^6.0.4",
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "capacitor-plugin-app-tracking-transparency": "^2.0.5",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^12.10.0",
    "lucide-react": "^0.546.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
